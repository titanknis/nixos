  "comb": {
    "prefix": "comb",
    "body": [
      "long long comb(int n, int k) {",
      "    if (k > n) return 0; ",
      "    if (k > n - k)",
      "        k = n - k;",
      "    long long res = 1;",
      "    for (int i = 1; i <= k; ++i)",
      "        res = res * (n - k + i) / i;",
      "    return res;",
      "}"
    ],
    "description": "Combinations function O(k) with symmetry"
  },

  "perm": {
    "prefix": "perm",
    "body": [
      "long long perm(int n, int k) {",
      "    if (k > n) return 0; ",
      "    long long res = 1;",
      "    for (int i = 0; i < k; ++i)",
      "        res *= (n - i);",
      "    return res;",
      "}"
    ],
    "description": "Permutations function O(k)"
  },

